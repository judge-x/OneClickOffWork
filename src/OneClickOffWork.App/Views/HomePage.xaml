<UserControl x:Class="OneClickOffWork.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Padding="22,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="工作规划" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="{Binding WorkQuote}"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Margin="0,6,0,0"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="一键下班"
                        Command="{Binding OffWorkCommand}"
                        Style="{StaticResource OffWorkButton}"
                        Margin="30,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource Card}" Padding="22,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="下班预设事项" FontSize="21" FontWeight="SemiBold"/>
                        <ScrollViewer Grid.Row="1"
                                      Margin="0,14,0,0"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ReminderPreviewItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource InputBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Content}"
                                                           Foreground="{DynamicResource SubtleTextBrush}"
                                                           FontSize="12"
                                                           Margin="0,5,0,0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="18,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="今日信息" FontSize="21" FontWeight="SemiBold"/>
                        <Grid Grid.Row="1" Height="136" VerticalAlignment="Top" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="0.95*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16,14">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TodayWeekText}"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding TodayDateText}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding TodayProgressText}"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="12"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Button Grid.Column="1"
                                    Command="{Binding RefreshWeatherCommand}"
                                    Style="{StaticResource InfoCardButton}"
                                    Margin="12,0,0,0"
                                    ToolTip="点击刷新天气">
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="48"
                                            Height="48"
                                            CornerRadius="24"
                                            Background="#E6F8F3"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding WeatherIcon}"
                                                   FontFamily="Segoe UI Emoji, Segoe UI Symbol"
                                                   FontSize="24"
                                                   Foreground="#0F766E"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding WeatherTemperature}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               TextWrapping="NoWrap"/>
                                    <StackPanel Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Margin="0,10,0,0"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding WeatherDescription}"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   TextWrapping="NoWrap"/>
                                        <TextBlock Text="{Binding WeatherCity}"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="今日上班任务" FontSize="21" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TodayCompletionText}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,18,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="添加"
                                Command="{Binding AddTaskCommand}"
                                Width="78"
                                Margin="10,0,0,0"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TodayTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="14"
                                            Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Style="{StaticResource TaskCheckBox}"
                                                      IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                      Command="{Binding DataContext.SaveTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap"
                                                       Margin="12,0"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2"
                                                    Content="删除"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="12,4"
                                                    MinHeight="30"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
