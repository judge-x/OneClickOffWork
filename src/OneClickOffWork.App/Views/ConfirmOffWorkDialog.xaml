<Window x:Class="OneClickOffWork.Views.ConfirmOffWorkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认下班" Width="620" Height="620" WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="24" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="下班前确认" FontSize="30" FontWeight="Bold"/>
                <TextBlock Text="逐项看一眼，确认后将立即息屏。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,8,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="18" Margin="0,20,0,14">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="剩余"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,3,12,0"/>
                    <TextBlock x:Name="CountdownText"
                               Grid.Column="1"
                               FontSize="34"
                               FontWeight="Bold"
                               Text="02:00"
                               LineHeight="40"
                               LineStackingStrategy="BlockLineHeight"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2"
                               Text="自动息屏"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               VerticalAlignment="Center"
                               Margin="12,3,0,0"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ReminderList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" Width="110" Click="Cancel_Click" Margin="0,0,10,0"/>
                <Button Content="确认下班" Width="130" Click="Confirm_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
