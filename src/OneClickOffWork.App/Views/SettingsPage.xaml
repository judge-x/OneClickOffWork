<UserControl x:Class="OneClickOffWork.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingInput" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="180"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettingCombo" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="180"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="设置" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="调整后台运行、倒计时、主题和通知偏好。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,18"/>
                    <CheckBox Content="开机自启动" IsChecked="{Binding StartWithWindows}"/>
                    <CheckBox Content="关闭窗口时最小化到托盘" IsChecked="{Binding MinimizeToTrayOnClose}"/>
                    <CheckBox Content="点击一键下班后自动倒计时" IsChecked="{Binding AutoCountdownAfterClick}"/>
                    <CheckBox Content="首次打开显示使用引导" IsChecked="{Binding ShowOnboarding}"/>
                    <CheckBox Content="执行前播放提示音" IsChecked="{Binding PlaySoundBeforePowerOff}"/>
                    <CheckBox Content="息屏前显示通知" IsChecked="{Binding ShowNotificationBeforePowerOff}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,18,0,0">
                <Grid MaxWidth="520" HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="默认倒计时（秒）" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding CountdownSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingInput}"/>
                    <TextBlock Grid.Row="1" Text="天气城市" VerticalAlignment="Center" Margin="0,18,0,0"/>
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding WeatherCity, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingInput}"
                             Margin="0,14,0,0"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,18,0,0">
                <Grid MaxWidth="520" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="主题" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              SelectedValue="{Binding Theme}"
                              SelectedValuePath="Tag"
                              Style="{StaticResource SettingCombo}">
                        <ComboBoxItem Content="跟随系统" Tag="System"/>
                        <ComboBoxItem Content="浅色" Tag="Light"/>
                        <ComboBoxItem Content="深色" Tag="Dark"/>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,18,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="备份设置" Command="{Binding BackupCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="恢复设置" Command="{Binding RestoreCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="恢复默认" Command="{Binding RestoreDefaultsCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="保存设置" Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
