<UserControl x:Class="OneClickOffWork.Views.TodayTaskPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="工作分析" FontSize="28" FontWeight="Bold"/>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,22,0,18">
                <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="14" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="今日完成" Foreground="{DynamicResource SubtleTextBrush}"/>
                        <TextBlock Text="{Binding TodayText}" FontSize="23" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="14" Padding="16" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="今日下班" Foreground="{DynamicResource SubtleTextBrush}"/>
                        <TextBlock Text="{Binding TodayOffWorkText}" FontSize="23" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="14" Padding="16" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="本月平均下班" Foreground="{DynamicResource SubtleTextBrush}"/>
                        <TextBlock Text="{Binding MonthAverageOffWorkText}" FontSize="23" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="14" Padding="16" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="本月完成率" Foreground="{DynamicResource SubtleTextBrush}"/>
                        <TextBlock Text="{Binding MonthPercent, StringFormat={}{0}%}" FontSize="23" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TabControl Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="{x:Type TabControl}">
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Padding" Value="18,8"/>
                        <Setter Property="Margin" Value="0,0,8,0"/>
                        <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Border x:Name="Root"
                                            CornerRadius="12"
                                            Background="{DynamicResource InputBackgroundBrush}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="月度">
                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding MonthText, StringFormat=月度任务：{0}}" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding MonthBars}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Height="16" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="8">
                                            <Border Width="{Binding Width}" Background="{StaticResource AccentBrush}" CornerRadius="8" HorizontalAlignment="Left"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Text}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </TabItem>

                <TabItem Header="年度">
                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding YearText, StringFormat=年度任务：{0}}" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding YearBars}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Height="14" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="7">
                                                <Border Width="{Binding Width}" Background="{StaticResource AccentBrush}" CornerRadius="7" HorizontalAlignment="Left"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Text}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
