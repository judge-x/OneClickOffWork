<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#2F7DFF</Color>
    <Color x:Key="AccentPressedColor">#1F5ECC</Color>
    <Color x:Key="DangerColor">#E84B5F</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <LinearGradientBrush x:Key="OffWorkButtonBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10B981" Offset="0"/>
        <GradientStop Color="#14B8A6" Offset="0.55"/>
        <GradientStop Color="#0EA5E9" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OffWorkButtonPressedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#059669" Offset="0"/>
        <GradientStop Color="#0D9488" Offset="0.55"/>
        <GradientStop Color="#0284C7" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LightWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F7FAFF" Offset="0"/>
        <GradientStop Color="#EEF3FB" Offset="0.48"/>
        <GradientStop Color="#F7F1FA" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DarkWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#111827" Offset="0"/>
        <GradientStop Color="#182033" Offset="0.5"/>
        <GradientStop Color="#211A2A" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="LightCardBackgroundBrush" Color="#EFFFFFFF"/>
    <SolidColorBrush x:Key="DarkCardBackgroundBrush" Color="#E5222A36"/>
    <SolidColorBrush x:Key="LightTextBrush" Color="#172033"/>
    <SolidColorBrush x:Key="DarkTextBrush" Color="#F4F7FB"/>
    <SolidColorBrush x:Key="LightSubtleTextBrush" Color="#657089"/>
    <SolidColorBrush x:Key="DarkSubtleTextBrush" Color="#B7C0D4"/>
    <SolidColorBrush x:Key="LightBorderBrushSoft" Color="#DCE4F0"/>
    <SolidColorBrush x:Key="DarkBorderBrushSoft" Color="#3A4658"/>
    <SolidColorBrush x:Key="LightInputBackgroundBrush" Color="#F7F9FD"/>
    <SolidColorBrush x:Key="DarkInputBackgroundBrush" Color="#151C28"/>

    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F7FAFF" Offset="0"/>
        <GradientStop Color="#EEF3FB" Offset="0.48"/>
        <GradientStop Color="#F7F1FA" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#EFFFFFFF"/>
    <SolidColorBrush x:Key="TextBrush" Color="#172033"/>
    <SolidColorBrush x:Key="SubtleTextBrush" Color="#657089"/>
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE4F0"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F7F9FD"/>
</ResourceDictionary>
